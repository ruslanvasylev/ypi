#!/bin/bash
# ypi — Y-Combinator Pi — Recursive Coding Agent
#
# Launches Pi with the canonical ypi recursive extension. The extension owns
# prompt injection; this wrapper only provides a friendly command and early env.
#
# Usage:
#   ypi                              # interactive recursive pi
#   ypi "What is in this repo?"      # one-shot with -p
#   ypi --provider anthropic --model claude-sonnet-4-5-20250929 "question"
#
# Environment overrides:
#   RLM_PROVIDER       — LLM provider override for root + sub-calls (default: Pi active/default provider)
#   RLM_MODEL          — LLM model override for root + sub-calls (default: Pi active/default model)
#   RLM_THINKING_LEVEL — thinking-level override for sub-calls (default: Pi active/default thinking)
#   RLM_MAX_DEPTH      — max recursion depth (default: 3)
#   RLM_TIMEOUT        — wall-clock seconds for entire recursive tree (default: none)
#   RLM_MAX_CALLS      — max total rlm_query invocations (default: none)
#   RLM_CHILD_MODEL    — model for all sub-calls at depth > 0 (default: same as root)
#   RLM_CHILD_PROVIDER — provider for RLM_CHILD_MODEL (default: same as root)
#   RLM_CHILD_THINKING_LEVEL — thinking level for all sub-calls at depth > 0
#   RLM_CHILD_MODELS   — comma-separated child-depth model list (depth 1,2,...)
#   RLM_CHILD_PROVIDERS — comma-separated child-depth provider list (depth 1,2,...)
#   RLM_CHILD_THINKING_LEVELS — comma-separated child-depth thinking list (depth 1,2,...)
#   RLM_JJ             — set to "0" to disable jj workspace isolation (default: 1)
#   RLM_EXTENSIONS     — set to "0" to disable Pi extensions (default: 1)
#   RLM_CHILD_EXTENSIONS — override extensions for depth > 0 (default: same as parent)
#   RLM_BUDGET         — max dollar spend for entire recursive tree (default: none)
#   RLM_JSON           — set to "0" to disable JSON mode / cost tracking (default: 1)
#   RLM_SHARED_SESSIONS — set to "0" to disable session log sharing (default: 1)
#   PI_TRACE_FILE      — path to trace log for all calls with timing (default: none)

set -euo pipefail

# Resolve the directory where ypi lives (and where rlm_query + SYSTEM_PROMPT.md are)
# Follow symlinks — npm install -g creates symlinks in .bin/ pointing to node_modules/ypi/
resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir target
    while [ -h "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        target="$(readlink "$source")"
        if [[ "$target" == /* ]]; then
            source="$target"
        else
            source="$dir/$target"
        fi
    done
    cd -P "$(dirname "$source")" && pwd
}

resolve_pi_bin() {
    if [ -n "${YPI_PI_BIN:-}" ]; then
        printf '%s\n' "$YPI_PI_BIN"
        return 0
    fi
    if command -v pi >/dev/null 2>&1; then
        command -v pi
        return 0
    fi
    local candidate
    for candidate in \
        "$SCRIPT_DIR/../.bin/pi" \
        "$SCRIPT_DIR/node_modules/.bin/pi" \
        "$SCRIPT_DIR/../@earendil-works/pi-coding-agent/dist/cli.js" \
        "$SCRIPT_DIR/node_modules/@earendil-works/pi-coding-agent/dist/cli.js"; do
        if [ -x "$candidate" ]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done
    return 1
}

SCRIPT_DIR="$(resolve_script_dir)"
if ! PI_BIN="$(resolve_pi_bin)"; then
    echo "ypi: could not find pi. Install @earendil-works/pi-coding-agent or set YPI_PI_BIN=/path/to/pi." >&2
    exit 127
fi
export YPI_PI_BIN="$PI_BIN"

# Put rlm_query on PATH so Pi's bash tool can find it
export PATH="$SCRIPT_DIR:$PATH"

# Initialize RLM environment — pass through all guardrails.
# Provider/model routing is applied after CLI parsing so explicit --provider / --model
# flags remain authoritative for the root Pi process.
export RLM_DEPTH="${RLM_DEPTH:-0}"
export RLM_MAX_DEPTH="${RLM_MAX_DEPTH:-3}"
export RLM_SYSTEM_PROMPT="$SCRIPT_DIR/SYSTEM_PROMPT.md"

# Guardrails — pass through if set, don't override
[ -n "${RLM_TIMEOUT:-}" ]        && export RLM_TIMEOUT
[ -n "${RLM_MAX_CALLS:-}" ]      && export RLM_MAX_CALLS
[ -n "${RLM_CHILD_MODEL:-}" ]    && export RLM_CHILD_MODEL
[ -n "${RLM_CHILD_PROVIDER:-}" ] && export RLM_CHILD_PROVIDER
[ -n "${RLM_CHILD_THINKING_LEVEL:-}" ] && export RLM_CHILD_THINKING_LEVEL
[ -n "${RLM_CHILD_MODELS:-}" ]   && export RLM_CHILD_MODELS
[ -n "${RLM_CHILD_PROVIDERS:-}" ] && export RLM_CHILD_PROVIDERS
[ -n "${RLM_CHILD_THINKING_LEVELS:-}" ] && export RLM_CHILD_THINKING_LEVELS
[ -n "${PI_TRACE_FILE:-}" ]      && export PI_TRACE_FILE
export RLM_JJ="${RLM_JJ:-1}"
export RLM_EXTENSIONS="${RLM_EXTENSIONS:-1}"
[ -n "${RLM_CHILD_EXTENSIONS:-}" ] && export RLM_CHILD_EXTENSIONS
[ -n "${RLM_BUDGET:-}" ]           && export RLM_BUDGET
export RLM_JSON="${RLM_JSON:-1}"
export RLM_SHARED_SESSIONS="${RLM_SHARED_SESSIONS:-1}"

# Session tree tracing — generate a trace ID that links all recursive sessions
export RLM_TRACE_ID="${RLM_TRACE_ID:-$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')}"

# Canonical ypi extension. Keep extensions/ypi.ts as a compatibility alias,
# but load recursive.ts so the wrapper and direct-extension path share runtime.
YPI_EXTENSION="$SCRIPT_DIR/extensions/recursive.ts"
if [ ! -f "$YPI_EXTENSION" ]; then
    echo "ypi: missing extension: $YPI_EXTENSION" >&2
    exit 1
fi
export YPI_EXTENSION_ROOT="$SCRIPT_DIR"
export YPI_EXTENSION_PATH="$YPI_EXTENSION"

# Wrapper mode opts into the shell-compatible rlm_query helper: its source is folded
# into the system prompt and its directory is kept on PATH for the bash tool. A bare
# `pi -e` / npm extension install leaves this unset and uses the native tool only.
export YPI_SHELL_HELPER=1

# Parse only ypi-owned flags and provider/model routing. All Pi prompt flags are
# passed through; the extension appends ypi's recursive prompt at agent start.
PASS_ARGS=()
HAS_PROVIDER=false
HAS_MODEL=false
SESSION_DIR_OVERRIDE=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --quiet|-q)
            shift
            ;;
        --provider)
            HAS_PROVIDER=true
            PASS_ARGS+=("$1")
            shift
            if [[ $# -gt 0 ]]; then
                PASS_ARGS+=("$1")
                shift
            fi
            ;;
        --provider=*)
            HAS_PROVIDER=true
            PASS_ARGS+=("$1")
            shift
            ;;
        --model)
            HAS_MODEL=true
            PASS_ARGS+=("$1")
            shift
            if [[ $# -gt 0 ]]; then
                PASS_ARGS+=("$1")
                shift
            fi
            ;;
        --model=*)
            HAS_MODEL=true
            PASS_ARGS+=("$1")
            shift
            ;;
        --session-dir)
            PASS_ARGS+=("$1")
            shift
            if [[ $# -gt 0 ]]; then
                SESSION_DIR_OVERRIDE="$1"
                PASS_ARGS+=("$1")
                shift
            fi
            ;;
        --session-dir=*)
            SESSION_DIR_OVERRIDE="${1#--session-dir=}"
            PASS_ARGS+=("$1")
            shift
            ;;
        --)
            PASS_ARGS+=("$1")
            shift
            while [[ $# -gt 0 ]]; do
                PASS_ARGS+=("$1")
                shift
            done
            ;;
        *)
            PASS_ARGS+=("$1")
            shift
            ;;
    esac
done
if [ -n "$SESSION_DIR_OVERRIDE" ] && [ -z "${RLM_SESSION_DIR:-}" ]; then
    export RLM_SESSION_DIR="$SESSION_DIR_OVERRIDE"
fi

# Launch Pi with the canonical recursive extension. User's own extensions are
# still discovered by Pi; this one is explicit so ypi is always active.
PI_ARGV=("$PI_BIN")
if [ "$HAS_PROVIDER" = false ] && [ -n "${RLM_PROVIDER:-}" ]; then
    PI_ARGV+=(--provider "$RLM_PROVIDER")
elif [ "$HAS_PROVIDER" = true ]; then
    # Explicit CLI provider should win for both root and recursive children.
    # The extension will seed RLM_PROVIDER from Pi's active root model.
    unset RLM_PROVIDER
fi
if [ "$HAS_MODEL" = false ] && [ -n "${RLM_MODEL:-}" ]; then
    PI_ARGV+=(--model "$RLM_MODEL")
elif [ "$HAS_MODEL" = true ]; then
    # Explicit CLI model should win for both root and recursive children.
    # The extension will seed RLM_MODEL from Pi's active root model.
    unset RLM_MODEL
fi
PI_ARGV+=(-e "$YPI_EXTENSION")
[ ${#PASS_ARGS[@]} -gt 0 ] && PI_ARGV+=("${PASS_ARGS[@]}")
exec "${PI_ARGV[@]}"
