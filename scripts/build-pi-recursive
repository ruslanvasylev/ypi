#!/usr/bin/env bash
# Assemble the pi-recursive publish view from the canonical root source.
#
# pi-recursive is the pure Pi extension (the `pi.extensions` surface, no `bin`). Its
# extension sources live canonically at the repo root (extensions/, SYSTEM_PROMPT.md) so
# the ypi wrapper and the tests share one source of truth. This script copies that source
# into pi-recursive/ as gitignored build artifacts.
#
# It is an explicit build step, NOT an npm lifecycle hook, so it composes with
# `bun pm pack --ignore-scripts` and this repo's no-lifecycle-scripts policy. Run it before
# `npm pack`/`npm publish` from pi-recursive/.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEST="$ROOT/pi-recursive"

mkdir -p "$DEST/extensions"
# Clean previously staged artifacts so a deleted source file cannot linger.
find "$DEST/extensions" -mindepth 1 -delete
rm -rf "$DEST/skills"
cp -R "$ROOT/extensions/." "$DEST/extensions/"
cp -R "$ROOT/skills" "$DEST/skills"
cp "$ROOT/SYSTEM_PROMPT.md" "$DEST/SYSTEM_PROMPT.md"
cp "$ROOT/LICENSE" "$DEST/LICENSE"

echo "Staged pi-recursive from canonical source: $(find "$DEST/extensions" -name '*.ts' | wc -l) extension files + $(find "$DEST/skills" -name SKILL.md | wc -l) skills + SYSTEM_PROMPT.md + LICENSE"
