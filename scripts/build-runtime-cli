#!/usr/bin/env bash
# Build/check the Node-executable projection of the canonical TypeScript CLI.
# dist/rlm_query.mjs is generated; extensions/ypi/*.ts remain the only mutable
# implementation owner.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUTPUT="$ROOT/dist/rlm_query.mjs"
CHECK=false
[ "${1:-}" = "--check" ] && CHECK=true

if ! command -v bun >/dev/null 2>&1; then
    echo "build-runtime-cli: bun is required" >&2
    exit 127
fi

TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/ypi_runtime_cli.XXXXXX")"
BUNDLE="$TMP_DIR/bundle.mjs"
TMP="$TMP_DIR/rlm_query.mjs"
trap 'rm -rf "$TMP_DIR"' EXIT

bun build "$ROOT/extensions/ypi/cli.ts" \
    --target=node \
    --format=esm \
    --outfile="$BUNDLE" >/dev/null
{
    echo '// GENERATED by scripts/build-runtime-cli; edit extensions/ypi/*.ts instead.'
    cat "$BUNDLE"
} > "$TMP"

if [ "$CHECK" = true ]; then
    if [ ! -f "$OUTPUT" ] || ! cmp -s "$TMP" "$OUTPUT"; then
        echo "build-runtime-cli: generated dist/rlm_query.mjs is stale" >&2
        echo "Run: scripts/build-runtime-cli" >&2
        exit 1
    fi
    echo "BUILD_RUNTIME_CLI=PASS mode=check"
    exit 0
fi

mkdir -p "$(dirname "$OUTPUT")"
install -m 0644 "$TMP" "$OUTPUT"
echo "BUILD_RUNTIME_CLI=PASS output=$OUTPUT"
