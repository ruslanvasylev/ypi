#!/usr/bin/env bash
# publish-packages — publish ypi + pi-recursive to npm in lockstep (local-first).
#
# Verifies release consistency (lockstep versions + a DATED changelog entry),
# stages pi-recursive, then publishes BOTH via the sops-backed `npm-publish`
# wrapper (ypi from the repo root; pi-recursive from its staged build dir).
#
# Usage:
#   scripts/publish-packages            # publish both
#   scripts/publish-packages --dry-run  # `npm publish --dry-run` for both, publish nothing
#
# Prereqs: `npm-publish` wrapper on PATH (injects the sops-encrypted npm token).

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

DRY=false
[ "${1:-}" = "--dry-run" ] && DRY=true

if [ "$DRY" != true ]; then
    ./scripts/assert-release-authorized
fi

if ! command -v npm-publish >/dev/null 2>&1; then
    echo "✗ npm-publish wrapper not found on PATH." >&2
    echo "  It runs 'npm publish' with the sops-encrypted token injected (token never in ~/.npmrc)." >&2
    exit 1
fi

echo "==> release consistency (lockstep + dated CHANGELOG)"
./scripts/check-release-consistency --require-dated

echo "==> canonical runtime typecheck + generated artifact freshness"
make typecheck-runtime check-runtime-cli

VER="$(node -e "console.log(require('./package.json').version)")"
echo "==> target version: $VER (ypi + pi-recursive in lockstep)"

echo "==> stage pi-recursive publish view"
./scripts/build-pi-recursive

echo "==> installed-package smoke gates"
make test-consumer-pack test-pi-recursive-pack

if [ "$DRY" = true ]; then
    echo "== DRY RUN: ypi =="
    npm publish --dry-run
    echo "== DRY RUN: pi-recursive =="
    ( cd pi-recursive && npm publish --dry-run )
    echo "✅ dry-run complete — nothing published"
    exit 0
fi

echo "==> publish ypi@$VER"
npm-publish .
echo "==> publish pi-recursive@$VER"
npm-publish ./pi-recursive

echo "✅ published ypi@$VER + pi-recursive@$VER"
echo "   verify (registry may lag a moment):"
echo "     npm view ypi version --prefer-online"
echo "     npm view pi-recursive version --prefer-online"
echo "   smoke the real install: YPI_TEST_REGISTRY_INSTALL=1 PKG_MIN_AGE_DAYS=0 make test-install-from-registry"
