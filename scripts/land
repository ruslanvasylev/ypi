#!/usr/bin/env bash
# Validate the exact clean feature-branch commit and push only that branch to an
# owner-verified origin. This helper never merges, tags, publishes, or releases.
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

DRY_RUN=0
if [ "${1:-}" = "--dry-run" ]; then
  DRY_RUN=1
elif [ -n "${1:-}" ]; then
  echo "usage: scripts/land [--dry-run]" >&2
  exit 2
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "scripts/land: Git checkout required" >&2
  exit 2
fi
BRANCH="$(git branch --show-current)"
case "$BRANCH" in
  ""|master|main)
    echo "scripts/land: refusing shared trunk '$BRANCH'; use a feature branch" >&2
    exit 2
    ;;
esac

if ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo "scripts/land: working tree must be clean so validation and delivery name the same commit" >&2
  exit 2
fi

mapfile -t PUSH_URLS < <(git remote get-url --push --all origin)
if [ "${#PUSH_URLS[@]}" -eq 0 ]; then
  echo "scripts/land: origin has no push URL" >&2
  exit 2
fi
for push_url in "${PUSH_URLS[@]}"; do
  "$ROOT_DIR/scripts/validate-push-owner" "$push_url"
done

HEAD_BEFORE="$(git rev-parse HEAD)"
"$ROOT_DIR/scripts/pre-push-checks"
"$ROOT_DIR/scripts/doctor"
"$ROOT_DIR/scripts/check-release-consistency"
"$ROOT_DIR/scripts/encrypt-prose" --check
HEAD_AFTER="$(git rev-parse HEAD)"
if [ "$HEAD_BEFORE" != "$HEAD_AFTER" ] || ! git diff --quiet || ! git diff --cached --quiet || [ -n "$(git ls-files --others --exclude-standard)" ]; then
  echo "scripts/land: checkout changed during validation; rerun on the final clean commit" >&2
  exit 2
fi

if [ "$DRY_RUN" = "1" ]; then
  echo "scripts/land: dry-run PASS commit=$HEAD_AFTER branch=$BRANCH"
  exit 0
fi

# Explicit branch refspec and disabled follow-tags prevent accidental tag or
# default-ref publication. The hook repeats owner and release checks.
YPI_SKIP_PUSH_CHECKS=1 git -c push.followTags=false push --no-follow-tags origin "HEAD:refs/heads/$BRANCH"
echo "scripts/land: pushed owned feature branch origin/$BRANCH at $HEAD_AFTER; merge/release not performed"
