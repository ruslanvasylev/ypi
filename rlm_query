#!/usr/bin/env bash
# rlm_query — Recursive Language Model sub-call for Pi.
#
# This is the Pi/bash equivalent of Python RLM's llm_query().
# Each invocation spawns a child Pi that can answer questions about context.
#
# Usage:
#   rlm_query "Analyze this and extract all dates"
#   echo "some text" | rlm_query "What is the main topic?"
#   sed -n '100,200p' "$CONTEXT" | rlm_query "Summarize this section"
#   rlm_query --fork "Continue working on this refactor"
#   rlm_query --async "Analyze the codebase"   # returns immediately with job JSON
#   echo "data" | rlm_query --async --notify $$ "Summarize this"
#
# If stdin has data (piped), that becomes the child's context.
# Otherwise, the child inherits the parent's $CONTEXT file.
#
# Flags:
#   --fork             Fork parent session into child (carries conversation history)
#                      Default: fresh session per child (only data context, no history)
#   --async            Spawn child in background, return immediately with job JSON
#                      Output goes to a temp file; sentinel touched when done
#   --notify PID       With --async: write result to target PID's peer inbox when done
#
# Environment:
#   RLM_DEPTH         — current recursion depth (default: 0)
#   RLM_MAX_DEPTH     — max recursion depth (default: 3)
#   RLM_PROVIDER      — LLM provider
#   RLM_MODEL         — LLM model
#   RLM_THINKING_LEVEL — Pi thinking level for child calls
#   RLM_SYSTEM_PROMPT — path to the RLM system prompt file
#   CONTEXT           — path to the current context file
#   RLM_STDIN         — set to "1" by the calling pattern to indicate piped input
#   RLM_TIMEOUT       — max wall‑clock seconds for the whole call chain
#   RLM_START_TIME    — epoch seconds when the root call started (auto‑set)
#   RLM_MAX_CALLS     — maximum total rlm_query invocations allowed
#   RLM_CALL_COUNT    — current count of invocations (auto‑incremented)
#   RLM_CHILD_MODEL   — model to use for all child calls (depth > 0)
#   RLM_CHILD_PROVIDER— provider to use with RLM_CHILD_MODEL (depth > 0)
#   RLM_CHILD_THINKING_LEVEL — thinking level to use for all child calls (depth > 0)
#   RLM_CHILD_MODELS  — comma-separated child-depth model list (depth 1,2,...)
#   RLM_CHILD_PROVIDERS — comma-separated child-depth provider list (depth 1,2,...)
#   RLM_CHILD_THINKING_LEVELS — comma-separated child-depth thinking list (depth 1,2,...)
#   RLM_JJ            — set to "0" to disable jj workspace isolation
#   RLM_EXTENSIONS    — set to "0" to disable Pi extensions (default: 1)
#   RLM_CHILD_EXTENSIONS — override extensions for depth > 0 (default: same as parent)
#   RLM_BUDGET        — max dollar spend for entire recursive tree (e.g. "0.50")
#   RLM_COST_FILE     — shared file tracking cumulative cost (auto‑created)
#   RLM_JSON          — set to "0" to disable JSON mode (plain text, no cost tracking)
#   RLM_TRACE_ID      — shared ID linking all sessions in a recursive tree
#   RLM_SESSION_DIR   — Pi session directory for this project
#   RLM_SESSION_FILE  — parent's session file (used with --fork)

set -euo pipefail

# Structured error helper
rlm_error() { echo "✗ $1" >&2; [ -n "${2:-}" ] && echo "  Why: $2" >&2; [ -n "${3:-}" ] && echo "  Fix: $3" >&2; }

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir target
    while [ -h "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        target="$(readlink "$source")"
        if [[ "$target" == /* ]]; then
            source="$target"
        else
            source="$dir/$target"
        fi
    done
    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

safe_trace_id() {
    printf '%s' "$1" | tr -c 'A-Za-z0-9._-' '_'
}

with_counter_lock() {
    local counter_file="$1"
    local lock_dir="${counter_file}.lock"
    local attempts=0
    mkdir -p "$(dirname "$counter_file")"
    until mkdir "$lock_dir" 2>/dev/null; do
        attempts=$((attempts + 1))
        if [ "$attempts" -gt 500 ]; then
            rlm_error "Call counter lock timed out" "$lock_dir stayed locked" "Remove stale *.lock directories in ${TMPDIR:-/tmp}"
            exit 1
        fi
        sleep 0.01
    done
}

next_call_count() {
    local initial="${RLM_CALL_COUNT:-0}"
    local current
    with_counter_lock "$RLM_CALL_COUNTER_FILE"
    if [ -f "$RLM_CALL_COUNTER_FILE" ]; then
        current="$(cat "$RLM_CALL_COUNTER_FILE" 2>/dev/null || echo "$initial")"
    else
        current="$initial"
    fi
    current="${current:-0}"
    RLM_CALL_COUNT=$(( current + 1 ))
    printf '%s\n' "$RLM_CALL_COUNT" > "$RLM_CALL_COUNTER_FILE"
    rm -rf "${RLM_CALL_COUNTER_FILE}.lock"
    export RLM_CALL_COUNT
}

timeout_prefix() {
    local seconds="$1"
    if command -v timeout >/dev/null 2>&1; then
        TIMEOUT_PREFIX=(timeout "$seconds")
    elif command -v gtimeout >/dev/null 2>&1; then
        TIMEOUT_PREFIX=(gtimeout "$seconds")
    elif command -v perl >/dev/null 2>&1; then
        TIMEOUT_PREFIX=(perl -e 'my $t=shift; my $pid=fork(); die "fork failed: $!" unless defined $pid; if ($pid == 0) { exec @ARGV; die "exec failed: $!" } local $SIG{ALRM}=sub{ kill "TERM", $pid; sleep 1; kill "KILL", $pid; exit 124; }; alarm $t; waitpid($pid, 0); exit($? >> 8);' "$seconds")
    else
        rlm_error "Timeout command unavailable" "RLM_TIMEOUT is set but neither timeout, gtimeout, nor perl is available" "Install GNU coreutils or unset RLM_TIMEOUT"
        exit 127
    fi
}

append_allowed_env() {
    local key
    for key in \
        HOME PATH TMPDIR TEMP TMP SHELL USER LOGNAME \
        PI_CODING_AGENT_DIR PI_CODING_AGENT_SESSION_DIR PI_PACKAGE_DIR PI_OFFLINE PI_TELEMETRY PI_SHARE_VIEWER_URL \
        ANTHROPIC_API_KEY ANTHROPIC_OAUTH_TOKEN COPILOT_GITHUB_TOKEN GH_TOKEN GITHUB_TOKEN HF_TOKEN ANT_LING_API_KEY OPENAI_API_KEY \
        AZURE_OPENAI_API_KEY AZURE_OPENAI_BASE_URL AZURE_OPENAI_RESOURCE_NAME AZURE_OPENAI_API_VERSION AZURE_OPENAI_DEPLOYMENT_NAME_MAP \
        DEEPSEEK_API_KEY NVIDIA_API_KEY GEMINI_API_KEY GROQ_API_KEY CEREBRAS_API_KEY XAI_API_KEY FIREWORKS_API_KEY TOGETHER_API_KEY \
        OPENROUTER_API_KEY AI_GATEWAY_API_KEY ZAI_API_KEY ZAI_CODING_CN_API_KEY MISTRAL_API_KEY MINIMAX_API_KEY MOONSHOT_API_KEY \
        OPENCODE_API_KEY KIMI_API_KEY CLOUDFLARE_API_KEY CLOUDFLARE_ACCOUNT_ID CLOUDFLARE_GATEWAY_ID \
        XIAOMI_API_KEY XIAOMI_TOKEN_PLAN_CN_API_KEY XIAOMI_TOKEN_PLAN_AMS_API_KEY XIAOMI_TOKEN_PLAN_SGP_API_KEY \
        AWS_PROFILE AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_BEARER_TOKEN_BEDROCK AWS_REGION \
        GOOGLE_CLOUD_API_KEY GOOGLE_APPLICATION_CREDENTIALS GOOGLE_CLOUD_PROJECT GCLOUD_PROJECT GOOGLE_CLOUD_LOCATION OLLAMA_API_KEY PORTKEY_API_KEY MINIMAX_CN_API_KEY \
        AWS_DEFAULT_REGION AWS_ENDPOINT_URL_BEDROCK_RUNTIME AWS_CONTAINER_CREDENTIALS_FULL_URI AWS_CONTAINER_CREDENTIALS_RELATIVE_URI AWS_WEB_IDENTITY_TOKEN_FILE \
        AZURE_API_VERSION CLOUDFLARE_API_HOST CLOUDFLARE_AI_GATEWAY_HOST CLOUDFLARE_AI_GATEWAY_ANTHROPIC_BASE_URL CLOUDFLARE_AI_GATEWAY_OPENAI_BASE_URL CLOUDFLARE_AI_GATEWAY_COMPAT_BASE_URL CLOUDFLARE_WORKERS_AI_BASE_URL; do
        if [ -n "${!key:-}" ]; then
            CHILD_ENV+=("$key=${!key}")
        fi
    done
    while IFS='=' read -r key _; do
        case "$key" in
            RLM_*|YPI_*|CONTEXT|PI_TRACE_FILE)
                CHILD_ENV+=("$key=${!key:-}")
                ;;
        esac
    done < <(env)
}

# ----------------------------------------------------------------------
# Parse flags
# ----------------------------------------------------------------------
FORK=false
ASYNC=false
NOTIFY_PID=""
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --fork) FORK=true; shift ;;
        --async) ASYNC=true; shift ;;
        --notify) NOTIFY_PID="$2"; shift 2 ;;
        *) break ;;
    esac
done

PROMPT="${1:?Usage: rlm_query [--fork] [--async] [--notify PID] \"your prompt here\"}"

# ----------------------------------------------------------------------
# Depth guard — refuse to go beyond max depth
# This is the only recursion limiter. Children get full tools/extensions.
# ----------------------------------------------------------------------
DEPTH="${RLM_DEPTH:-0}"
MAX_DEPTH="${RLM_MAX_DEPTH:-3}"

# Fail closed: a malformed depth config must not bypass the recursion limiter.
case "$DEPTH" in ''|*[!0-9]*)
    rlm_error "Invalid RLM_DEPTH" "RLM_DEPTH='$DEPTH' is not a non-negative integer" "Unset RLM_DEPTH or set it to an integer >= 0"
    exit 1 ;;
esac
case "$MAX_DEPTH" in ''|*[!0-9]*)
    rlm_error "Invalid RLM_MAX_DEPTH" "RLM_MAX_DEPTH='$MAX_DEPTH' is not a non-negative integer" "Unset RLM_MAX_DEPTH or set it to an integer >= 0"
    exit 1 ;;
esac

NEXT_DEPTH=$((DEPTH + 1))

if [ "$NEXT_DEPTH" -gt "$MAX_DEPTH" ]; then
    rlm_error "Max depth exceeded" "At depth $DEPTH of $MAX_DEPTH" "Increase RLM_MAX_DEPTH or simplify the task"
    exit 1
fi

# ----------------------------------------------------------------------
# Stale temp reaper — runs once per root invocation (depth 0 only)
# Cleans up leaked files from crashed/killed processes (SIGKILL skips traps)
# ----------------------------------------------------------------------
if [ "$DEPTH" -eq 0 ]; then
    (
        # Delete rlm temp files older than 2 hours whose parent process is gone
        find "${TMPDIR:-/tmp}" -maxdepth 1 -name 'rlm_*' -mmin +120 -delete 2>/dev/null
        # Remove stale jj workspace directories older than 2 hours
        find "${TMPDIR:-/tmp}" -maxdepth 1 \( -name 'rlm_ws_*' -o -name 'ypi_ws_*' \) -type d -mmin +120 -exec rm -rf {} + 2>/dev/null
    ) &
fi

PROVIDER="${RLM_PROVIDER:-}"
MODEL="${RLM_MODEL:-}"
THINKING_LEVEL="${RLM_THINKING_LEVEL:-}"
SYSTEM_PROMPT_FILE="${RLM_SYSTEM_PROMPT:-}"

# ----------------------------------------------------------------------
# Timeout start time initialization
# Anchor the wall-clock budget when a top-level (depth 0) tree begins so a
# long-running parent never passes down a stale start time. Children inherit it.
# ----------------------------------------------------------------------
if [ "$DEPTH" -eq 0 ] || [ -z "${RLM_START_TIME:-}" ]; then
    export RLM_START_TIME=$(date +%s)
fi

# ----------------------------------------------------------------------
# Session tree — each child gets a persisted session file
# Trace ID groups all sessions from one recursive invocation.
# ----------------------------------------------------------------------
if [ -z "${RLM_TRACE_ID:-}" ]; then
    export RLM_TRACE_ID=$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')
fi
SAFE_TRACE_ID="$(safe_trace_id "$RLM_TRACE_ID")"
# Normalize in place so session filenames, async IDs, trace lines, and child env all use
# the path-safe value rather than raw user input.
export RLM_TRACE_ID="$SAFE_TRACE_ID"
export RLM_CALL_COUNTER_FILE="${RLM_CALL_COUNTER_FILE:-${TMPDIR:-/tmp}/rlm_calls_${SAFE_TRACE_ID}.counter}"

# ----------------------------------------------------------------------
# Call counting & max‑calls guard
# ----------------------------------------------------------------------
next_call_count
# RLM_MAX_CALLS=N permits calls 1..N; only the (N+1)th invocation is rejected.
if [ -n "${RLM_MAX_CALLS:-}" ] && [ "$RLM_CALL_COUNT" -gt "$RLM_MAX_CALLS" ]; then
    rlm_error "Max calls exceeded" "$RLM_MAX_CALLS of $RLM_MAX_CALLS calls already used" "Increase RLM_MAX_CALLS or reduce recursion depth"
    exit 1
fi

# Initialize cost file if budget is set but no file exists yet
if [ -n "${RLM_BUDGET:-}" ] && [ -z "${RLM_COST_FILE:-}" ]; then
    export RLM_COST_FILE="${TMPDIR:-/tmp}/rlm_cost_${SAFE_TRACE_ID}.jsonl"
fi

# ----------------------------------------------------------------------
# Budget guard — check cumulative cost before proceeding
# ----------------------------------------------------------------------
if [ -n "${RLM_BUDGET:-}" ] && [ -n "${RLM_COST_FILE:-}" ] && [ -f "$RLM_COST_FILE" ]; then
    CURRENT_COST=$(python3 -c "
import json
total = 0.0
with open('$RLM_COST_FILE') as f:
    for line in f:
        line = line.strip()
        if line:
            try: total += json.loads(line).get('cost', 0)
            except: pass
print(f'{total:.6f}')
" 2>/dev/null || echo "0")
    OVER=$(python3 -c "print('yes' if $CURRENT_COST >= $RLM_BUDGET else 'no')" 2>/dev/null || echo "no")
    if [ "$OVER" = "yes" ]; then
        rlm_error "Budget exceeded" "Spent \$$CURRENT_COST of \$$RLM_BUDGET budget" "Increase RLM_BUDGET or simplify the task"
        exit 1
    fi
fi

CHILD_SESSION_FILE=""
if [ "${RLM_SHARED_SESSIONS:-1}" != "0" ] && [ -n "${RLM_SESSION_DIR:-}" ]; then
    mkdir -p "$RLM_SESSION_DIR"
    CHILD_SESSION_FILE="${RLM_SESSION_DIR}/${RLM_TRACE_ID}_d${NEXT_DEPTH}_c${RLM_CALL_COUNT}.jsonl"

    # --fork: copy parent session to give child full conversation history
    if [ "$FORK" = true ] && [ -n "${RLM_SESSION_FILE:-}" ] && [ -f "${RLM_SESSION_FILE:-}" ]; then
        cp "$RLM_SESSION_FILE" "$CHILD_SESSION_FILE"
    fi
fi

# ----------------------------------------------------------------------
# Trace logging (optional)
# ----------------------------------------------------------------------
if [ -n "${PI_TRACE_FILE:-}" ]; then
    echo "[$(date +%H:%M:%S.%3N)] depth=$DEPTH→$NEXT_DEPTH PID=$$ PPID=$PPID call=$RLM_CALL_COUNT trace=$RLM_TRACE_ID fork=$FORK prompt: ${PROMPT:0:120}" >> "$PI_TRACE_FILE"
fi

# ----------------------------------------------------------------------
# Temporary child context file
# ----------------------------------------------------------------------
CHILD_CONTEXT=$(mktemp "${TMPDIR:-/tmp}/rlm_ctx_d${NEXT_DEPTH}.XXXXXX")
COMBINED_PROMPT=""

# Write prompt to a file for symbolic access — agents can grep/sed the original
# question instead of relying on in-context token copying.
PROMPT_FILE=$(mktemp "${TMPDIR:-/tmp}/rlm_prompt_d${NEXT_DEPTH}.XXXXXX")
echo "$PROMPT" > "$PROMPT_FILE"

# ----------------------------------------------------------------------
# jj workspace isolation — give recursive children their own working copy
# ----------------------------------------------------------------------
JJ_WORKSPACE=""
JJ_WS_NAME=""
if [ "${RLM_JJ:-1}" != "0" ] \
   && command -v jj &>/dev/null \
   && jj root &>/dev/null 2>&1; then
    JJ_WS_NAME="rlm-d${NEXT_DEPTH}-$$"
    JJ_WORKSPACE=$(mktemp -d "${TMPDIR:-/tmp}/rlm_ws_d${NEXT_DEPTH}.XXXXXX")
    if ! jj workspace add --name "$JJ_WS_NAME" "$JJ_WORKSPACE" &>/dev/null; then
        JJ_WORKSPACE=""
        JJ_WS_NAME=""
    fi
fi

# Cleanup: remove temp context + forget jj workspace (updated in run section below)
# In async mode, the child needs these files — skip cleanup (child cleans up after itself)
if [ "$ASYNC" != true ]; then
trap '{
    rm -f "$CHILD_CONTEXT" "$PROMPT_FILE"
    rm -f "${COMBINED_PROMPT:-}"
    if [ -n "$JJ_WS_NAME" ]; then
        jj workspace forget "$JJ_WS_NAME" 2>/dev/null || true
    fi
    if [ -n "$JJ_WORKSPACE" ]; then
        rm -rf "$JJ_WORKSPACE"
    fi
}' EXIT
fi
trap 'rlm_error "Interrupted" "Received signal" "Re-run the command"; exit 130' INT TERM

# ----------------------------------------------------------------------
# Detect piped stdin
# ----------------------------------------------------------------------
HAS_STDIN=false
if [ -n "${RLM_STDIN:-}" ]; then
    HAS_STDIN=true
elif [ -p /dev/stdin ]; then
    HAS_STDIN=true
fi

if [ "$HAS_STDIN" = true ]; then
    cat > "$CHILD_CONTEXT"

    # Some CI runners expose stdin as an empty pipe even when nothing was piped
    # to rlm_query. In that case, preserve inherited CONTEXT unless stdin was
    # explicitly signaled via RLM_STDIN.
    if [ ! -s "$CHILD_CONTEXT" ] && [ -z "${RLM_STDIN:-}" ] && [ -n "${CONTEXT:-}" ] && [ -f "${CONTEXT:-}" ]; then
        cp "$CONTEXT" "$CHILD_CONTEXT"
    fi
else
    if [ -n "${CONTEXT:-}" ] && [ -f "${CONTEXT:-}" ]; then
        cp "$CONTEXT" "$CHILD_CONTEXT"
    fi
fi

# ----------------------------------------------------------------------
# Model/thinking routing for child calls (depth > 0)
# ----------------------------------------------------------------------
comma_entry() {
    local list="${1:-}"
    local index="$2"
    [ -n "$list" ] || return 0
    python3 - "$list" "$index" <<'PY'
import sys
parts = [part.strip() for part in sys.argv[1].split(',')]
idx = int(sys.argv[2]) - 1
print(parts[idx] if 0 <= idx < len(parts) else "")
PY
}

DEPTH_MODEL="$(comma_entry "${RLM_CHILD_MODELS:-}" "$NEXT_DEPTH")"
DEPTH_PROVIDER="$(comma_entry "${RLM_CHILD_PROVIDERS:-}" "$NEXT_DEPTH")"
DEPTH_THINKING="$(comma_entry "${RLM_CHILD_THINKING_LEVELS:-}" "$NEXT_DEPTH")"

if [ "$NEXT_DEPTH" -gt 0 ]; then
    if [ -n "$DEPTH_MODEL" ]; then
        MODEL="$DEPTH_MODEL"
    elif [ -n "${RLM_CHILD_MODEL:-}" ]; then
        MODEL="${RLM_CHILD_MODEL}"
    fi

    if [ -n "$DEPTH_PROVIDER" ]; then
        PROVIDER="$DEPTH_PROVIDER"
    elif [ -n "${RLM_CHILD_PROVIDER:-}" ] && { [ -n "$DEPTH_MODEL" ] || [ -n "${RLM_CHILD_MODEL:-}" ]; }; then
        PROVIDER="${RLM_CHILD_PROVIDER}"
    fi

    if [ -n "$DEPTH_THINKING" ]; then
        THINKING_LEVEL="$DEPTH_THINKING"
    elif [ -n "${RLM_CHILD_THINKING_LEVEL:-}" ]; then
        THINKING_LEVEL="${RLM_CHILD_THINKING_LEVEL}"
    fi
fi

# ----------------------------------------------------------------------
# Spawn child Pi with tools, extensions, and session
# ----------------------------------------------------------------------
export CONTEXT="$CHILD_CONTEXT"
export RLM_PROMPT_FILE="$PROMPT_FILE"
export RLM_DEPTH="$NEXT_DEPTH"
export RLM_MAX_DEPTH="$MAX_DEPTH"
export RLM_PROVIDER="$PROVIDER"
export RLM_MODEL="$MODEL"
export RLM_THINKING_LEVEL="$THINKING_LEVEL"
export RLM_SYSTEM_PROMPT="${SYSTEM_PROMPT_FILE:-}"
export RLM_START_TIME="${RLM_START_TIME}"
export RLM_TIMEOUT="${RLM_TIMEOUT:-}"
export RLM_TRACE_ID="${RLM_TRACE_ID}"
export RLM_SESSION_DIR="${RLM_SESSION_DIR:-}"
export RLM_BUDGET="${RLM_BUDGET:-}"
export RLM_COST_FILE="${RLM_COST_FILE:-}"
export RLM_SHARED_SESSIONS="${RLM_SHARED_SESSIONS:-1}"
export YPI_EXTENSION_ROOT="${YPI_EXTENSION_ROOT:-}"
export YPI_EXTENSION_PATH="${YPI_EXTENSION_PATH:-}"
export YPI_EXTENSION_PROMPT_MODE="${YPI_EXTENSION_PROMPT_MODE:-}"

# At max depth: remove rlm_query from PATH so the child can't recurse.
# The child still gets full tools (bash, read, write, edit) — it just
# can't spawn sub-agents. The depth guard above is a safety net.
if [ "$NEXT_DEPTH" -ge "$MAX_DEPTH" ]; then
    export PATH=$(echo "$PATH" | tr ':' '\n' | grep -v "^${SCRIPT_DIR}$" | paste -sd ':' -)
fi

if [ -n "$CHILD_SESSION_FILE" ]; then
    export RLM_SESSION_FILE="$CHILD_SESSION_FILE"
else
    unset RLM_SESSION_FILE
fi

PI_BIN="${YPI_PI_BIN:-pi}"

CMD_ARGS=(-p)
[ -n "$PROVIDER" ] && CMD_ARGS+=(--provider "$PROVIDER")
[ -n "$MODEL" ] && CMD_ARGS+=(--model "$MODEL")
[ -n "$THINKING_LEVEL" ] && CMD_ARGS+=(--thinking "$THINKING_LEVEL")

if [ -z "$JJ_WORKSPACE" ] && [ "${RLM_UNSAFE_NO_JJ_WRITE:-0}" != "1" ]; then
    CMD_ARGS+=(--tools read,grep,find,ls,rlm_query)
fi

# Extensions: on by default, configurable per-instance like model routing.
# Always disable ambient extension discovery; ypi's own extension is loaded
# explicitly below (when enabled) via -e "$YPI_EXTENSION_PATH".
CHILD_EXT="${RLM_EXTENSIONS:-1}"
if [ "$NEXT_DEPTH" -gt 0 ] && [ -n "${RLM_CHILD_EXTENSIONS:-}" ]; then
    CHILD_EXT="${RLM_CHILD_EXTENSIONS}"
fi
CMD_ARGS+=(--no-extensions)

if [ "${RLM_CHILD_DISCOVERY:-0}" != "1" ]; then
    CMD_ARGS+=(--no-skills --no-prompt-templates --no-themes --no-context-files --no-approve)
fi

# Session: use dedicated file if we have a session dir, otherwise ephemeral
if [ -n "$CHILD_SESSION_FILE" ]; then
    CMD_ARGS+=(--session "$CHILD_SESSION_FILE")
else
    CMD_ARGS+=(--no-session)
fi

# Prefer the canonical ypi extension when the root session provided it. Fall
# back to --system-prompt so rlm_query still works standalone.
USE_YPI_EXTENSION=false
if [ "$CHILD_EXT" != "0" ] && [ -n "${YPI_EXTENSION_PATH:-}" ] && [ -f "${YPI_EXTENSION_PATH:-}" ]; then
    CMD_ARGS+=(-e "$YPI_EXTENSION_PATH")
    USE_YPI_EXTENSION=true
fi

# Build combined system prompt with rlm_query source embedded when no ypi
# extension is available for this child.
COMBINED_PROMPT=""
if [ "$USE_YPI_EXTENSION" != true ] && [ -n "$SYSTEM_PROMPT_FILE" ] && [ -f "$SYSTEM_PROMPT_FILE" ]; then
    COMBINED_PROMPT=$(mktemp "${TMPDIR:-/tmp}/rlm_system_prompt.XXXXXX")
    cat "$SYSTEM_PROMPT_FILE" > "$COMBINED_PROMPT"
    SELF_SOURCE="$SCRIPT_DIR/rlm_query"
    if [ -f "$SELF_SOURCE" ]; then
        cat >> "$COMBINED_PROMPT" << 'SYSEOF'

## SECTION 6 – rlm_query Implementation

Below is the full source of `rlm_query`. You are running inside this infrastructure.
Understanding it helps you use recursion effectively and respect guardrails.

```bash
SYSEOF
        cat "$SELF_SOURCE" >> "$COMBINED_PROMPT"
        echo '```' >> "$COMBINED_PROMPT"
    fi
    CMD_ARGS+=(--system-prompt "$COMBINED_PROMPT")
fi

# Timeout wrapper
TIMEOUT_PREFIX=()
if [ -n "${RLM_TIMEOUT:-}" ]; then
    ELAPSED=$(( $(date +%s) - RLM_START_TIME ))
    REMAINING=$(( RLM_TIMEOUT - ELAPSED ))
    if [ "$REMAINING" -le 0 ]; then
        rlm_error "Timeout exceeded" "Ran for ${ELAPSED}s of ${RLM_TIMEOUT}s" "Increase RLM_TIMEOUT or simplify the task"
        exit 124
    fi
    timeout_prefix "$REMAINING"
fi

CHILD_ENV=()
append_allowed_env

# Enter jj workspace if available (child gets isolated working copy)
if [ -n "$JJ_WORKSPACE" ]; then
    cd "$JJ_WORKSPACE"
fi

# ----------------------------------------------------------------------
# Async mode — spawn child in background and return immediately
# ----------------------------------------------------------------------
if [ "$ASYNC" = true ]; then
    ASYNC_ID="rlm_async_${RLM_TRACE_ID}_c${RLM_CALL_COUNT}_$(head -c 4 /dev/urandom | od -An -tx1 | tr -d ' \n')"
    ASYNC_OUTPUT="${TMPDIR:-/tmp}/${ASYNC_ID}.txt"
    ASYNC_SENTINEL="${TMPDIR:-/tmp}/${ASYNC_ID}.done"

    # Build the full command
    CHILD_CMD=(env -i "${CHILD_ENV[@]}" "${TIMEOUT_PREFIX[@]}" "$PI_BIN" "${CMD_ARGS[@]}" "$PROMPT")

    # Spawn in background: run child, capture output, touch sentinel, optionally notify
    (
        "${CHILD_CMD[@]}" > "$ASYNC_OUTPUT" 2>&1
        touch "$ASYNC_SENTINEL"

        # If --notify PID was given, write to that peer's inbox
        if [ -n "$NOTIFY_PID" ]; then
            INBOX_DIR=$(find /tmp/pi_peer_* -maxdepth 0 -type d 2>/dev/null | while read d; do
                if [ -f "$d/meta.json" ] && grep -q "\"pid\":$NOTIFY_PID" "$d/meta.json" 2>/dev/null; then
                    echo "$d"; break
                fi
            done)
            if [ -n "$INBOX_DIR" ] && [ -d "$INBOX_DIR" ]; then
                # Build the inbox line with python3 so child output containing quotes,
                # backslashes, newlines, or control characters can never break the JSON.
                MSG=$(RLM_NOTIFY_PID="$$" \
                      RLM_NOTIFY_ID="async_${ASYNC_ID}" \
                      RLM_NOTIFY_TS="$(date -Iseconds)" \
                      python3 - "$ASYNC_OUTPUT" <<'PYJSON'
import json, os, sys
try:
    with open(sys.argv[1], "r", errors="replace") as fh:
        result = fh.read()[-50000:]
except OSError:
    result = ""
print(json.dumps({
    "from_pid": int(os.environ["RLM_NOTIFY_PID"]),
    "from_project": "rlm_query",
    "message": "[rlm_query --async result]\n\n" + result,
    "timestamp": os.environ["RLM_NOTIFY_TS"],
    "id": os.environ["RLM_NOTIFY_ID"],
}))
PYJSON
)
                if [ -n "$MSG" ]; then
                    printf '%s\n' "$MSG" >> "$INBOX_DIR/inbox.jsonl"
                fi
            fi
        fi

        # Clean up temp files the parent skipped
        rm -f "$CHILD_CONTEXT" "$PROMPT_FILE" "${COMBINED_PROMPT:-}"
        if [ -n "$JJ_WS_NAME" ]; then
            jj workspace forget "$JJ_WS_NAME" 2>/dev/null || true
        fi
        if [ -n "$JJ_WORKSPACE" ]; then
            rm -rf "$JJ_WORKSPACE"
        fi
    ) &
    ASYNC_PID=$!
    disown $ASYNC_PID 2>/dev/null || true

    # Return job metadata immediately
    cat <<EOF
{"job_id": "$ASYNC_ID", "output": "$ASYNC_OUTPUT", "sentinel": "$ASYNC_SENTINEL", "pid": $ASYNC_PID}
EOF
    exit 0
fi

# ----------------------------------------------------------------------
# Run child Pi — JSON mode (default) or plain text
# JSON mode streams text to stdout and captures cost via fd 3.
# ----------------------------------------------------------------------
COST_OUT=$(mktemp "${TMPDIR:-/tmp}/rlm_cost_out.XXXXXX")
ERR_OUT=$(mktemp "${TMPDIR:-/tmp}/rlm_stderr.XXXXXX")
trap '{
    rm -f "$CHILD_CONTEXT" "$PROMPT_FILE"
    rm -f "${COMBINED_PROMPT:-}"
    rm -f "$COST_OUT" "$ERR_OUT"
    if [ -n "$JJ_WS_NAME" ]; then
        jj workspace forget "$JJ_WS_NAME" 2>/dev/null || true
    fi
    if [ -n "$JJ_WORKSPACE" ]; then
        rm -rf "$JJ_WORKSPACE"
    fi
}' EXIT

if [ "${RLM_JSON:-1}" != "0" ]; then
    # JSON mode: get structured cost + stream text
    # Replace -p with --mode json, pipe through parser
    JSON_CMD_ARGS=()
    for arg in "${CMD_ARGS[@]}"; do
        [ "$arg" = "-p" ] && continue
        JSON_CMD_ARGS+=("$arg")
    done
    JSON_CMD_ARGS+=(--mode json)

    PARSER="$SCRIPT_DIR/rlm_parse_json"

    set +e
    env -i "${CHILD_ENV[@]}" "${TIMEOUT_PREFIX[@]}" "$PI_BIN" "${JSON_CMD_ARGS[@]}" "$PROMPT" 2>"$ERR_OUT" | python3 "$PARSER" 3>"$COST_OUT"
    PIPE_STATUS=("${PIPESTATUS[@]}")
    set -e
    RC="${PIPE_STATUS[0]}"
    PARSER_RC="${PIPE_STATUS[1]:-0}"
    if [ "$PARSER_RC" -ne 0 ] && [ "$RC" -eq 0 ]; then
        RC="$PARSER_RC"
    fi

    # Record cost if we got data
    if [ -s "$COST_OUT" ] && [ -n "${RLM_COST_FILE:-}" ]; then
        cat "$COST_OUT" >> "$RLM_COST_FILE"
    fi
    if [ "$RC" -ne 0 ] && [ -s "$ERR_OUT" ]; then
        cat "$ERR_OUT" >&2
    fi

    # Log cost to trace
    if [ -s "$COST_OUT" ] && [ -n "${PI_TRACE_FILE:-}" ]; then
        COST_DATA=$(cat "$COST_OUT")
        ELAPSED=$(( $(date +%s) - RLM_START_TIME ))
        echo "[$(date +%Y-%m-%dT%H:%M:%S%z)] depth=$DEPTH COMPLETED exit=$RC elapsed=${ELAPSED}s cost=$COST_DATA" >> "$PI_TRACE_FILE"
    elif [ -n "${PI_TRACE_FILE:-}" ]; then
        ELAPSED=$(( $(date +%s) - RLM_START_TIME ))
        echo "[$(date +%Y-%m-%dT%H:%M:%S%z)] depth=$DEPTH COMPLETED exit=$RC elapsed=${ELAPSED}s" >> "$PI_TRACE_FILE"
    fi
else
    # Plain text mode (RLM_JSON=0): no cost tracking
    set +e
    env -i "${CHILD_ENV[@]}" "${TIMEOUT_PREFIX[@]}" "$PI_BIN" "${CMD_ARGS[@]}" "$PROMPT"
    RC=$?
    set -e

    if [ -n "${PI_TRACE_FILE:-}" ]; then
        ELAPSED=$(( $(date +%s) - RLM_START_TIME ))
        echo "[$(date +%Y-%m-%dT%H:%M:%S%z)] depth=$DEPTH COMPLETED exit=$RC elapsed=${ELAPSED}s" >> "$PI_TRACE_FILE"
    fi
fi

exit $RC
