#!/usr/bin/env bash
# rlm_query — thin CLI adapter for ypi's canonical TypeScript recursion runtime.
# Set YPI_LEGACY_IMPL=1 to use the retained shell implementation during the
# convergence window; the fallback remains shipped and tested.

set -euo pipefail

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir target
    while [ -h "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        target="$(readlink "$source")"
        if [[ "$target" == /* ]]; then source="$target"; else source="$dir/$target"; fi
    done
    cd -P "$(dirname "$source")" && pwd
}

resolve_pi_bin() {
    if [ -n "${YPI_PI_BIN:-}" ]; then printf '%s\n' "$YPI_PI_BIN"; return 0; fi
    local candidate
    for candidate in \
        "$SCRIPT_DIR/../.bin/pi" \
        "$SCRIPT_DIR/node_modules/.bin/pi" \
        "$SCRIPT_DIR/../@earendil-works/pi-coding-agent/dist/cli.js" \
        "$SCRIPT_DIR/node_modules/@earendil-works/pi-coding-agent/dist/cli.js"; do
        if [ -x "$candidate" ]; then printf '%s\n' "$candidate"; return 0; fi
    done
    if command -v pi >/dev/null 2>&1; then command -v pi; return 0; fi
    return 1
}

SCRIPT_DIR="$(resolve_script_dir)"
# The executable owns its package root. Do not inherit stale paths from a
# different installation; explicit embedders use the YPI_CLI_* overrides.
export YPI_EXTENSION_ROOT="${YPI_CLI_ROOT_OVERRIDE:-$SCRIPT_DIR}"
export YPI_EXTENSION_PATH="${YPI_CLI_EXTENSION_OVERRIDE:-$YPI_EXTENSION_ROOT/extensions/recursive.ts}"
export RLM_MAX_DEPTH="${RLM_MAX_DEPTH:-3}"
export RLM_MAX_CALLS="${RLM_MAX_CALLS:-128}"
export RLM_SYSTEM_PROMPT="${YPI_CLI_SYSTEM_PROMPT_OVERRIDE:-$YPI_EXTENSION_ROOT/SYSTEM_PROMPT.md}"
if ! YPI_PI_BIN="$(resolve_pi_bin)"; then
    echo "✗ Could not find package-local or PATH pi" >&2
    echo "  Fix: install @earendil-works/pi-coding-agent or set YPI_PI_BIN" >&2
    exit 127
fi
export YPI_PI_BIN
if [ "${YPI_LEGACY_IMPL:-0}" = "1" ]; then
    export YPI_RLM_IMPLEMENTATION=legacy
    exec "$SCRIPT_DIR/rlm_query.legacy" "$@"
fi
export YPI_RLM_IMPLEMENTATION=canonical

NODE_BIN="${YPI_NODE_BIN:-node}"
if ! command -v "$NODE_BIN" >/dev/null 2>&1; then
    echo "✗ Node.js is required for rlm_query" >&2
    echo "  Why: the canonical recursion runtime is implemented in TypeScript/Node" >&2
    echo "  Fix: install Node.js >= 22.19 or set YPI_NODE_BIN" >&2
    exit 127
fi

exec "$NODE_BIN" --no-warnings "$SCRIPT_DIR/dist/rlm_query.mjs" "$@"
