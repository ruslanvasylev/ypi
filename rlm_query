#!/usr/bin/env bash
# rlm_query — thin CLI adapter for ypi's canonical TypeScript recursion runtime.
# Set YPI_LEGACY_IMPL=1 to use the retained shell implementation during the
# convergence window; the fallback remains shipped and tested.

set -euo pipefail

resolve_script_dir() {
    local source="${BASH_SOURCE[0]}"
    local dir target
    while [ -h "$source" ]; do
        dir="$(cd -P "$(dirname "$source")" && pwd)"
        target="$(readlink "$source")"
        if [[ "$target" == /* ]]; then source="$target"; else source="$dir/$target"; fi
    done
    cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
# The executable owns its package root. Do not inherit a stale root from a
# different parent installation; explicit embedding uses YPI_CLI_ROOT_OVERRIDE.
export YPI_EXTENSION_ROOT="${YPI_CLI_ROOT_OVERRIDE:-$SCRIPT_DIR}"
if [ "${YPI_LEGACY_IMPL:-0}" = "1" ]; then
    exec "$SCRIPT_DIR/rlm_query.legacy" "$@"
fi

NODE_BIN="${YPI_NODE_BIN:-node}"
if ! command -v "$NODE_BIN" >/dev/null 2>&1; then
    echo "✗ Node.js is required for rlm_query" >&2
    echo "  Why: the canonical recursion runtime is implemented in TypeScript/Node" >&2
    echo "  Fix: install Node.js >= 22.19 or set YPI_NODE_BIN" >&2
    exit 127
fi

exec "$NODE_BIN" --no-warnings "$SCRIPT_DIR/dist/rlm_query.mjs" "$@"
